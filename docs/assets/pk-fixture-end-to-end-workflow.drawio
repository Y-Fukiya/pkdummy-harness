        <mxCell id="subtitle" value="Purpose: create reproducible workflow fixtures for SDTM-like, ADPC, NCA, and PopPK pipeline testing. Not clinical inference, dose selection, or regulatory model validation." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=13;fontColor=#4B5563;" parent="1" vertex="1">
